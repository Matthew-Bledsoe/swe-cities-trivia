<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="/styles.css" />
</head>
<body>
    <div class="HP">
            <a href="/">
                <h1 class="Logo">Cities Trivia</h1>
            </a>
            <nav class = "NavBar">
                <hr class="vertical">
                <a href="/">Home</a>
                <hr class="vertical">
                <a href="/leaderboard">Leaderboard</a>
                <hr class="vertical">
                <a href="/daily">Daily Quiz</a>
                <hr class="vertical">
                <a href="/practice">Practice Quiz</a>
                <hr class="vertical">
                <a href="/account">Account</a>
                <hr class="vertical">
            </nav>
        </div>
         <h1>Leaderboard</h1>
    <div class="leaderboard-box">
        <ol start="<%= (currentPage - 1) * 30 + 1 %>">
            <% players.forEach(player => { %>
            <li><strong><%= player.username %></strong>: 
            <%= player.score %> points</li><% }) %>
        </ol>

        <div class="pages">
            <% if (currentPage > 1) { %>
                <a href="/leaderboard?page=<%= currentPage - 1 %>">Prev</a><% } %>

            <% for (let i = 1; i <= totalPages; i++) { %>
                <a href="/leaderboard?page=<%= i %>" class="<%= i === currentPage ? 'active' : '' %>"><%= i %></a><% } %>

            <% if (currentPage < totalPages) { %>
                <a href="/leaderboard?page=<%= currentPage + 1 %>">Next</a><% } %>
        </div>
    </div>
</body>
</html>